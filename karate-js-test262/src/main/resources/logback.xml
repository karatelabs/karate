<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging config for the test262 runner.

  A single file `target/test262/progress.log` is overwritten per run and
  captures the startup banner, periodic [progress] lines, and the final
  Summary / Aborted line. FAIL lines and per-test metadata go to stdout
  only — that data already lives (with full fidelity) in
  target/test262/results.jsonl and results.jsonl.partial, and mirroring
  it into the log would just be duplication without a new signal.

  Progress.log is meant for `tail -f` during a run and for post-hoc
  "what pace did it go at / when did it abort" forensics. Anything
  beyond that should come from the JSONL files.
-->
<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>target/test262/progress.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Runner traffic goes only to the file; the runner also writes to stdout
         directly, so we don't want the logger to double-print. -->
    <logger name="io.karatelabs.js.test262" level="INFO" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Everything else (libraries, karate-js itself) goes to console at WARN. -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
